# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft (Azure AD) ─────────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── Facebook ─────────────────────────────────────────────────────────────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cloudflare R2 (Storage de PDFs) ─────────────────────────────────────────
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=todaatividade-pdfs
CLOUDFLARE_R2_PUBLIC_URL=

# ─── Mercado Pago ─────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
# Gerado em: MP Dashboard → Suas integrações → Webhooks → Assinatura secreta
MERCADOPAGO_WEBHOOK_SECRET=

# ─── Resend (E-mail transacional) ─────────────────────────────────────────────
# Crie em: https://resend.com → API Keys
RESEND_API_KEY=

# ─── .NET API (Backend) ───────────────────────────────────────────────────────
DOTNET_API_URL=http://localhost:5000
DOTNET_API_KEY=

# ─── Meta Pixel ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Cron Jobs (Vercel Cron) ──────────────────────────────────────────────────
# Segredo para autenticar chamadas do Vercel Cron — gere com: openssl rand -base64 32
CRON_SECRET=

# ─── Sentry (Monitoramento de erros) ─────────────────────────────────────────
# Crie em: https://sentry.io → Projects → DSN
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Opcionais (para upload de source maps no build):
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ─── Stripe (Assinaturas) ─────────────────────────────────────────────────────
# Crie em: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Gere em: Stripe Dashboard → Developers → Webhooks → Add endpoint
# Endpoint: https://www.todaatividade.com.br/api/webhooks/stripe
# Eventos: customer.subscription.created, customer.subscription.updated,
#          customer.subscription.deleted, invoice.paid, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=
# ID do preço da assinatura mensal/anual — copie do Stripe Dashboard → Products
STRIPE_PRICE_ID=
